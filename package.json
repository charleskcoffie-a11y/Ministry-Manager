{
  "name": "ministry-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://charleskcoffie-a11y.github.io/Ministry-Manager",
  "scripts": {
    "dev": "vite",
    "dev:secure": "node server/appServer.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "preview:secure": "node server/appServer.mjs --preview",
    "seed:wesley": "node scripts/seedWesley.js",
    "build:wesley:diary": "node scripts/buildWesleyDiary.js",
    "songs:dedupe": "node scripts/dedupeSongs.js",
    "songs:dedupe:apply": "node scripts/dedupeSongs.js --apply",
    "songs:dedupe:report": "node scripts/dedupeSongs.js --report reports/song-conflicts.json",
    "songs:dedupe:csv": "node scripts/exportSongConflictCsv.js",
    "songs:favorites:sync": "node scripts/syncSongFavoriteDuplicates.js",
    "songs:favorites:sync:apply": "node scripts/syncSongFavoriteDuplicates.js --apply",
    "songs:converted:export": "python scripts/syncConvertedHymns.py",
    "songs:converted:apply": "python scripts/syncConvertedHymns.py --apply",
    "songs:canvas:favorites:schema": "node scripts/ensureSongCanvasFavoritesSchema.js",
    "sync:hymn-stories": "node scripts/syncHymnStoryMappings.js",
    "wesley:status": "node scripts/wesleyStatus.js",
    "check:wesley:themes": "node scripts/checkWesleyQuoteThemes.js",
    "check:wesley:themes:strict": "node scripts/checkWesleyQuoteThemes.js --strict",
    "hooks:install": "git config core.hooksPath .githooks",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@supabase/supabase-js": "^2.86.0",
    "autoprefixer": "^10.4.23",
    "html2pdf.js": "^0.12.1",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.555.0",
    "mammoth": "^1.6.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^3.11.174",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "gh-pages": "^6.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
