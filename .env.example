# Gemini AI API Key
# Get your API key from: https://aistudio.google.com/app/apikey
# Example only. Keep this server-side and never commit a real key.
# Used by the local secure proxy and by the Supabase Edge Function secret.
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase Configuration
# Required if you want the frontend to call your own Supabase Edge Function,
# including when the app is hosted on GitHub Pages.
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: only needed for Node helper scripts that create schema automatically.
# Never expose this in client-side code.
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
